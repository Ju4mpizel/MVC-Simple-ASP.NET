@model ControlInventario.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<div class="page-header">
    <h1><i class="bi bi-eye me-2"></i>Detalles del Producto</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="card-custom">
    <div class="card-custom-body">
        <dl class="dl-minimal">
            <dt>@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd>@Html.DisplayFor(model => model.Nombre)</dd>

            <dt>@Html.DisplayNameFor(model => model.Precio)</dt>
            <dd>@Model.Precio.ToString("C")</dd>

            <dt>Categoría</dt>
            <dd>
                @if (Model.Categoria != null)
                {
                    <span class="badge-cat">@Model.Categoria.Nombre</span>
                }
                else
                {
                    <span class="text-muted">Sin categoría</span>
                }
            </dd>
        </dl>
    </div>
</div>
