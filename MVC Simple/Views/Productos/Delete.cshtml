@model ControlInventario.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="page-header">
    <h1><i class="bi bi-trash me-2 text-danger"></i>Eliminar Producto</h1>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
    <i class="bi bi-exclamation-triangle"></i>
    <span>¿Estás seguro de que deseas eliminar este producto? Esta acción no se puede deshacer.</span>
</div>

<div class="card-custom">
    <div class="card-custom-body">
        <dl class="dl-minimal">
            <dt>@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd>@Html.DisplayFor(model => model.Nombre)</dd>

            <dt>@Html.DisplayNameFor(model => model.Precio)</dt>
            <dd>@Model.Precio.ToString("C")</dd>

            <dt>Categoría</dt>
            <dd>
                @if (Model.Categoria != null)
                {
                    <span class="badge-cat">@Model.Categoria.Nombre</span>
                }
                else
                {
                    <span class="text-muted">Sin categoría</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i>Eliminar
            </button>
        </form>
    </div>
</div>
