@model IEnumerable<ControlInventario.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="page-header">
    <h1><i class="bi bi-cube me-2"></i>Productos</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Producto
    </a>
</div>

@if (!Model.Any())
{
    <div class="card-custom">
        <div class="card-custom-body empty-state">
            <i class="bi bi-archive"></i>
            <p>No hay productos registrados todavía.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Crear Primer Producto
            </a>
        </div>
    </div>
}
else
{
    <div class="card-custom">
        <div class="card-custom-body p-0">
            <table class="table-minimal">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                        <th>@Html.DisplayNameFor(model => model.Precio)</th>
                        <th>Categoría</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">@Html.DisplayFor(model => item.Nombre)</td>
                            <td>@item.Precio.ToString("C")</td>
                            <td>
                                @if (item.Categoria != null)
                                {
                                    <span class="badge-cat">@item.Categoria.Nombre</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end action-links">
                                <a asp-action="Edit" asp-route-id="@item.Id" title="Editar">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" title="Detalles">
                                    <i class="bi bi-eye"></i> Detalles
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
