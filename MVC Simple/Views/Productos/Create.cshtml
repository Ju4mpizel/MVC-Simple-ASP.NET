@model ControlInventario.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2"></i>Nuevo Producto</h1>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card-custom">
            <div class="card-custom-header">Información del Producto</div>
            <div class="card-custom-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="form-group">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Laptop HP" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Precio" class="form-label"></label>
                        <input asp-for="Precio" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Precio" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CategoriaId" class="form-label">Categoría</label>
                        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
                            <option value="">— Selecciona una Categoría —</option>
                        </select>
                        <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
