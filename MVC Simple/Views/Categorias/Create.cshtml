@model ControlInventario.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2"></i>Nueva Categoría</h1>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card-custom">
            <div class="card-custom-header">Información de la Categoría</div>
            <div class="card-custom-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="form-group">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Electrónica" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
