@model ControlInventario.Models.Categoria

@{
    ViewData["Title"] = "Detalles de Categoría";
}

<div class="page-header">
    <h1><i class="bi bi-eye me-2"></i>Detalles de Categoría</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">
            <i class="bi bi-pencil me-1"></i>Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="card-custom">
    <div class="card-custom-body">
        <dl class="dl-minimal">
            <dt>@Html.DisplayNameFor(model => model.Nombre)</dt>
            <dd>@Html.DisplayFor(model => model.Nombre)</dd>
        </dl>
    </div>
</div>
